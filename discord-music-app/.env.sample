# ===========================================
# Discord Music Bot - Environment Configuration
# ===========================================
# Copy this file to:
#   .env        - for local development
#   .env.docker - for Docker deployment
# ===========================================

# Discord Bot (required)
DISCORD_TOKEN=your_bot_token
APP_ID=your_application_id

# Guild ID (required for web UI authentication)
# Restricts web UI access to members of this Discord server
GUILD_ID=your_discord_server_id

# OAuth (required)
DISCORD_CLIENT_SECRET=your_client_secret
OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback
# For Docker: OAUTH_REDIRECT_URI=https://music.yourdomain.com/api/auth/callback

# Server (required)
JWT_SECRET=generate_a_random_32_char_string
WEB_URL=http://localhost:5173
# WEB_URL is used for CORS and as the post-login redirect target after the OAuth
# flow. It is read from this env var (not the request origin) to avoid host-header
# injection, so set it to your real frontend URL in production.
NODE_ENV=development
# For production/Docker: Omit NODE_ENV or set to any value other than "development"

# Reverse-proxy hop count (optional). Leave UNSET for direct local runs. Set to 1
# when running behind a single reverse proxy / Docker so the rate limiter sees the
# real client IP. This is a hop count, not a boolean — do not set it to "true".
# TRUST_PROXY=1

# Server port (optional, defaults to 3000)
# PORT=3000

# Logging level (optional): error | warn | info | debug. Defaults to info.
# LOG_LEVEL=info

# yt-dlp safety limits (optional)
# Max concurrent yt-dlp metadata processes (search/info/playlist). Default 4.
# YT_DLP_MAX_CONCURRENCY=4
# Max callers queued waiting for a metadata slot; further requests are rejected. Default 50.
# YT_DLP_MAX_QUEUE=50
# Watchdog: kill a playback stream that produces no output within this many ms. Default 15000.
# YT_DLP_STREAM_TIMEOUT_MS=15000

# yt-dlp (optional - auto-detects Docker vs local paths)
# YT_DLP_PATH is auto-detected: /app/bin/yt-dlp (Docker), ./bin/yt-dlp (local), or system yt-dlp
# Only set this if you need a custom path:
# YT_DLP_PATH=/custom/path/to/yt-dlp

# Cookies for age-restricted YouTube content (optional)
# YT_DLP_COOKIES=./cookies.txt
# For Docker: YT_DLP_COOKIES=/app/cookies.txt

# Spotify (optional)
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
