# ===========================================
# Discord Music Bot - Environment Configuration
# ===========================================
# Copy this file to:
#   .env        - for local development
#   .env.docker - for Docker deployment
# ===========================================

# Discord Bot (required)
DISCORD_TOKEN=your_bot_token
APP_ID=your_application_id
PUBLIC_KEY=your_public_key
GUILD_ID=your_discord_server_id

# OAuth (required)
DISCORD_CLIENT_SECRET=your_client_secret
OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback
# For Docker: OAUTH_REDIRECT_URI=https://music.yourdomain.com/api/auth/callback

# Server (required)
PORT=3000
JWT_SECRET=generate_a_random_32_char_string
WEB_URL=http://localhost:5173
# For Docker: WEB_URL=https://music.yourdomain.com
NODE_ENV=development
# For Docker: NODE_ENV=production

# yt-dlp (optional)
YT_DLP_PATH=./bin/yt-dlp
# For Docker: YT_DLP_PATH=/app/bin/yt-dlp
# YT_DLP_COOKIES=          # Path to cookies file for age-restricted content
# For Docker: YT_DLP_COOKIES=/app/cookies.txt

# Spotify (optional)
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
