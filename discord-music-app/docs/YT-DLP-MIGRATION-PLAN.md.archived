## Phase 2A: Core YouTube Functions

**Team:** Core (Agent A)
**Dependencies:** Phase 1
**Parallelizable With:** Phase 2B, 2C, Phase 4
**File:** `src/music/youtube.js`

### Tasks

- [ ] **2A.1** Add new imports (child_process, util, stream)
- [ ] **2A.2** Define YT_DLP_PATH constant
- [ ] **2A.3** Implement `isValidUrl()` function
- [ ] **2A.4** Implement `search()` function
- [ ] **2A.5** Implement `getInfo()` function

### Code: Imports and Constants

```javascript
import { execFile, spawn } from 'child_process';
import { promisify } from 'util';
import { PassThrough } from 'stream';

const execFileAsync = promisify(execFile);
const YT_DLP_PATH = process.env.YT_DLP_PATH || 'yt-dlp';
```

### Code: isValidUrl()

```javascript
export function isValidUrl(url) {
  try {
    const urlObj = new URL(url);
    const validHosts = [
      'youtube.com',
      'www.youtube.com',
      'youtu.be',
      'm.youtube.com',
      'music.youtube.com'
    ];
    return validHosts.some(host => urlObj.hostname === host);
  } catch {
    return false;
  }
}
```

### Code: search()

```javascript
export async function search(query, limit = 5) {
  try {
    console.log('Searching YouTube for:', query);

    const { stdout } = await execFileAsync(YT_DLP_PATH, [
      `ytsearch${limit}:${query}`,
      '--dump-json',
      '--flat-playlist',
      '--no-warnings',
      '--ignore-errors'
    ], { maxBuffer: 10 * 1024 * 1024 });

    const results = stdout
      .trim()
      .split('\n')
      .filter(line => line)
      .map(line => {
        const data = JSON.parse(line);
        return {
          title: data.title || 'Unknown',
          url: `https://www.youtube.com/watch?v=${data.id}`,
          duration: data.duration || 0,
          thumbnail: data.thumbnail || data.thumbnails?.[0]?.url || null,
          channel: data.channel || data.uploader || 'Unknown'
        };
      });

    console.log('Search results:', JSON.stringify(results, null, 2));
    return results;
  } catch (error) {
    console.error('YouTube search error:', error);
    return [];
  }
}
```

### Code: getInfo()

```javascript
export async function getInfo(url) {
  try {
    if (!isValidUrl(url)) {
      return null;
    }

    const { stdout } = await execFileAsync(YT_DLP_PATH, [
      url,
      '--dump-json',
      '--no-download',
      '--no-warnings'
    ]);

    const data = JSON.parse(stdout);

    return {
      title: data.title,
      url: data.webpage_url || url,
      duration: data.duration || 0,
      thumbnail: data.thumbnail || data.thumbnails?.[0]?.url || null,
      channel: data.channel || data.uploader || 'Unknown'
    };
  } catch (error) {
    console.error('YouTube info error:', error);
    return null;
  }
}
```

### Acceptance Criteria

- [ ] Imports compile without errors
- [ ] `isValidUrl()` correctly validates YouTube URLs
- [ ] `search()` returns array of track objects
- [ ] `getInfo()` returns track info object for valid URL
- [ ] Functions handle errors gracefully (return empty array/null)

