## Phase 2B: Streaming Implementation

**Team:** Core (Agent B)
**Dependencies:** Phase 1
**Parallelizable With:** Phase 2A, 2C, Phase 4
**File:** `src/music/youtube.js`

### Tasks

- [ ] **2B.1** Implement `getStream()` function
- [ ] **2B.2** Implement `getStreamWithRetry()` function (optional enhancement)
- [ ] **2B.3** Add proper error handling and logging

### Code: getStream()

```javascript
export async function getStream(url) {
  console.log('Getting stream for URL:', url);

  const ytdlp = spawn(YT_DLP_PATH, [
    url,
    '-f', 'bestaudio[ext=webm]/bestaudio/best',
    '-o', '-',
    '--no-warnings',
    '--no-playlist',
    '--quiet'
  ]);

  const stream = new PassThrough();

  ytdlp.stdout.pipe(stream);

  ytdlp.stderr.on('data', (data) => {
    console.error('yt-dlp stderr:', data.toString());
  });

  ytdlp.on('error', (error) => {
    console.error('yt-dlp process error:', error);
    stream.destroy(error);
  });

  ytdlp.on('close', (code) => {
    if (code !== 0 && code !== null) {
      console.error(`yt-dlp exited with code ${code}`);
    }
  });

  return {
    stream,
    type: 'arbitrary'
  };
}
```

### Code: getStreamWithRetry() (Optional Enhancement)

```javascript
export async function getStreamWithRetry(url, maxRetries = 3) {
  for (let i = 0; i < maxRetries; i++) {
    try {
      return await getStream(url);
    } catch (error) {
      if (i === maxRetries - 1) throw error;
      await new Promise(r => setTimeout(r, 1000 * Math.pow(2, i)));
    }
  }
}
```

### Acceptance Criteria

- [ ] `getStream()` returns object with `stream` and `type` properties
- [ ] Stream emits data when piped
- [ ] Errors are logged and stream is destroyed on failure
- [ ] Process cleanup occurs on close

---

## Phase 2C: Playlist Support

**Team:** Core (Agent C)
**Dependencies:** Phase 1
**Parallelizable With:** Phase 2A, 2B, Phase 4
**File:** `src/music/youtube.js`

### Tasks

- [ ] **2C.1** Implement `isPlaylist()` function
- [ ] **2C.2** Implement `getPlaylist()` function

### Code: isPlaylist()

```javascript
export function isPlaylist(url) {
  try {
    const urlObj = new URL(url);
    return urlObj.searchParams.has('list') && !urlObj.searchParams.has('v');
  } catch {
    return false;
  }
}
```

### Code: getPlaylist()

```javascript
export async function getPlaylist(url, limit = 50) {
  try {
    const { stdout } = await execFileAsync(YT_DLP_PATH, [
      url,
      '--dump-json',
      '--flat-playlist',
      '--no-warnings',
      '--ignore-errors',
      '--playlist-end', String(limit)
    ], { maxBuffer: 10 * 1024 * 1024 });

    const results = stdout
      .trim()
      .split('\n')
      .filter(line => line)
      .map(line => {
        const data = JSON.parse(line);
        return {
          title: data.title || 'Unknown',
          url: `https://www.youtube.com/watch?v=${data.id}`,
          duration: data.duration || 0,
          thumbnail: data.thumbnail || data.thumbnails?.[0]?.url || null,
          channel: data.channel || data.uploader || 'Unknown'
        };
      });

    return results;
  } catch (error) {
    console.error('YouTube playlist error:', error);
    return [];
  }
}
```

### Acceptance Criteria

- [ ] `isPlaylist()` correctly identifies playlist URLs
- [ ] `isPlaylist()` returns false for single video URLs
- [ ] `getPlaylist()` returns array of track objects
- [ ] Playlist limit parameter is respected
- [ ] Errors return empty array

